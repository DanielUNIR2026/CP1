pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/DanielUNIR2026/CP1.git'
        }

    stage('Build') {
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    sh 'ls'
        }
    }

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        sh '''
                                export PYTHONPATH='/Users/dani/elRepo'
                                pytest --junitxml=result-unit.xml test//unit
                        '''
                    }
                }
            }
            
            stage('Rest') {
                steps {
                    sh '''
                        export FLASK_APP=app//api.py
                        export FLASK_ENV=development
                        flask run
                         java -jar C://Unir//Ejercicios//wiremock//wiremock-jre8-standalone-2.28.0.jar --port 9090 --root-dir test//wiremock
                        export PYTHONPATH=%WORKSPACE%
                        pytest --junitxml=result-rest.xml test//rest
                    '''
                }    
            }    
        }
    }
    
    stage ('Results') {
        steps {
            junit 'result*.xml'
        }
    }
  }
}
